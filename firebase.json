{
    "hosting":  {
                    "public":  "dist",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ],
                    "site":  "bella-customers-orders-816a4",
                    "headers":  [
                                    {
                                        "source":  "/sw.js",
                                        "headers":  [
                                                        {
                                                            "key":  "Cache-Control",
                                                            "value":  "no-cache"
                                                        }
                                                    ]
                                    },
                                    {
                                        "source":  "/manifest.webmanifest",
                                        "headers":  [
                                                        {
                                                            "key":  "Cache-Control",
                                                            "value":  "public, max-age=3600"
                                                        }
                                                    ]
                                    }
                                ]
                }
}
